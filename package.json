{
  "name": "mr-context",
  "version": "1.0.0",
  "description": "Multi-Repository Context Agent — semantic graph context for AI-assisted development via GitHub Copilot",
  "homepage": "https://github.com/eonio-dev/mr-context",
  "repository": {
    "type": "git",
    "url": "https://github.com/eonio-dev/mr-context.git"
  },
  "license": "MIT",
